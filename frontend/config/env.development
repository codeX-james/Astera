# Development Environment Configuration
# Copy to .env.local for local development

NEXT_PUBLIC_NETWORK=testnet

# Testnet contract IDs (deploy your own or use shared testnet instances)
NEXT_PUBLIC_INVOICE_CONTRACT_ID=
NEXT_PUBLIC_POOL_CONTRACT_ID=
NEXT_PUBLIC_USDC_TOKEN_ID=

# Optional testnet EURC
NEXT_PUBLIC_EURC_TOKEN_ID=

# Development-specific overrides (optional)
# NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
# NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
